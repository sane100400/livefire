# 행사 당일 이 파일을 .env 로 복사 후 실제 값으로 교체
# cp .env.example .env && vim .env

# ── 필수 시크릿 (없으면 서버 시작 시 KeyError 크래시) ─────────────────
ADMIN_SECRET=replace_before_event
TOKEN_TEAM_A=replace_before_event
TOKEN_TEAM_B=replace_before_event
TOKEN_TEAM_C=replace_before_event
TOKEN_TEAM_D=replace_before_event
TOKEN_TEAM_E=replace_before_event
TOKEN_TEAM_F=replace_before_event

# ── 팀 서비스 IP (기본값: 192.168.0.10-15) ───────────────────────────
# IP_TEAM_A=192.168.0.10
# IP_TEAM_B=192.168.0.11
# IP_TEAM_C=192.168.0.12
# IP_TEAM_D=192.168.0.13
# IP_TEAM_E=192.168.0.14
# IP_TEAM_F=192.168.0.15

# ── 경로 (기본값 사용 시 주석 처리 유지) ─────────────────────────────
# VULN_SPEC_DIR=/app/vuln_specs
# DB_PATH=/app/game_state.db
# COORDINATOR_URL=http://localhost:9000
